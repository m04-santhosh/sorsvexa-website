generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id          String   @id @default(cuid())
  fullName    String
  company     String?
  email       String
  phone       String
  industry    String?
  service     String?
  budget      String?
  description String
  status      String   @default("New")
  createdAt   DateTime @default(now())
}

model OtpRequest {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

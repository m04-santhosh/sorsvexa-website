generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id          String   @id @default(cuid())
  fullName    String
  company     String?
  email       String
  phone       String
  industry    String?
  service     String?
  budget      String?
  description String
  status      String   @default("New")
  createdAt   DateTime @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
